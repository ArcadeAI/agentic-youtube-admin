FROM oven/bun:1.3 AS base
WORKDIR /app

# Copy package manifests + lockfile
COPY package.json bun.lock ./
COPY apps/server/package.json apps/server/
COPY apps/web/package.json apps/web/
COPY packages/arcade/package.json packages/arcade/
COPY packages/auth/package.json packages/auth/
COPY packages/config/package.json packages/config/
COPY packages/db/package.json packages/db/
COPY packages/env/package.json packages/env/
COPY packages/ui/package.json packages/ui/

# Copy prisma config + schema + tsconfig so postinstall (prisma generate) works
COPY packages/config packages/config
COPY packages/db/prisma.config.ts packages/db/
COPY packages/db/prisma/schema packages/db/prisma/schema
COPY packages/db/tsconfig.json packages/db/

# Install dependencies (postinstall runs prisma generate)
RUN bun install

# Copy full source
COPY . .

# Build server
RUN bun run build

EXPOSE 3000
CMD ["bun", "run", "apps/server/dist/index.mjs"]
